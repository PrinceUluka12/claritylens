# .env.example
# ============================================================
# Copy this file to .env before starting the server.
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# .env is gitignored — never commit it.
# .env.example is committed — it documents every setting.
# ============================================================

# --- Database ---
# Matches the credentials in docker-compose.yml exactly.
# If you change these, change them in both files.
DATABASE_URL=postgresql://claritylens:claritylens@localhost:5432/claritylens

# --- File storage ---
# Where uploaded PDFs land on disk
STORAGE_UPLOADS_DIR=./storage/uploads
# Where extracted plain text is saved after PDF parsing
STORAGE_EXTRACTED_DIR=./storage/extracted

# --- Model weight paths ---
# These folders will be empty until you run the training scripts
ML_EMBEDDER_PATH=./ml/models/embedder
ML_CLASSIFIER_PATH=./ml/models/classifier
ML_NER_PATH=./ml/models/ner
ML_QA_PATH=./ml/models/qa

# --- Inference settings ---
# CPU NOTE: 256 is the hard limit. Do not raise this.
# DistilBERT attention is O(n²) — 512 tokens takes 4x longer than 256.
ML_MAX_SEQ_LEN=256

# CPU NOTE: 8 chunks per forward pass is the sweet spot on CPU.
# Lower this to 4 if you get memory errors during inference.
ML_BATCH_SIZE=8

# How many words per clause chunk when splitting a document
ML_CHUNK_SIZE=200

# How many words overlap between adjacent chunks.
# Overlap prevents a clause from being split at a boundary and losing context.
ML_CHUNK_OVERLAP=50

# --- CUAD dataset ---
CUAD_LOCAL_PATH=./ml/data/cuad
CUAD_PROCESSED_PATH=./ml/data/processed

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
# Set to false in production
API_RELOAD=true